# Local development env vars
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real keys.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# "ollama" uses local Ollama (no key needed)
# "groq"   uses Groq API (free at console.groq.com)
# "openai" uses OpenAI API
LLM_PROVIDER=ollama

# Model name (leave blank to use the provider default)
# LLM_MODEL=llama3.2

# ── API Keys ──────────────────────────────────────────────────────────────────
# GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...

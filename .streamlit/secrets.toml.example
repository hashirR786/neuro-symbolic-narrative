# ──────────────────────────────────────────────────────────────────────────────
# Streamlit Secrets template
# ──────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   Local  : copy this file to .streamlit/secrets.toml  (already git-ignored)
#            and fill in your values.
#   Cloud  : paste the KEY=VALUE pairs directly into
#            Streamlit Cloud → App Settings → Secrets (no file needed).
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM Backend ───────────────────────────────────────────────────────────────
# Choose one provider.  Groq is recommended for free cloud deployment.

# Option A — Groq (free, fast, llama3 models)
LLM_PROVIDER = "groq"
GROQ_API_KEY = "gsk_YOUR_GROQ_KEY_HERE"
LLM_MODEL    = "llama-3.1-8b-instant"   # or "llama3-8b-8192"

# Option B — OpenAI
# LLM_PROVIDER   = "openai"
# OPENAI_API_KEY = "sk-..."
# LLM_MODEL      = "gpt-4o-mini"

# Option C — Local Ollama (local dev only, won't work on Streamlit Cloud)
# LLM_PROVIDER = "ollama"
# LLM_MODEL    = "llama3.2"

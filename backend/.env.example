# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose: ollama | groq | openai
LLM_PROVIDER=groq

# Model name (optional — uses provider default if omitted)
LLM_MODEL=llama-3.1-8b-instant

# Required when LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here

# Required when LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here

# ── Ollama (local) ────────────────────────────────────────────────────────────
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# Ollama runs at http://localhost:11434 by default (no API key needed)

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Deployment (Render / Railway) ─────────────────────────────────────────────
# PORT is set automatically by most hosting platforms
# PORT=8000
